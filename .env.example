# TS3 Server Configuration (used by TS3AudioBot, NOT by backend directly)
TS3_SERVER_HOST=your-ts3-server.com
TS3_SERVER_PORT=9987

# TS3AudioBot Configuration
# Docker: http://ts3audiobot:58913 (leave as-is, set by docker-compose)
TS3AUDIOBOT_URL=http://ts3audiobot:58913
# Get API key from ts3audiobot logs on first run: look for "Created new api-token"
TS3AUDIOBOT_API_KEY=

# Backend
BACKEND_PORT=3001
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET

# Default admin login (change immediately after first login!)
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=CHANGE_THIS

# Spotify (optional)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://YOUR_DOMAIN/api/spotify/callback

# Production image prefix (docker-compose.prod.yml)
# Set to: ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO_NAME
GHCR_IMAGE_PREFIX=ghcr.io/changeme/musicbot
VERSION=latest
